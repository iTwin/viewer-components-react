{
  "name": "vcr-performance-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark:tree-widget": "cross-env BENCHMARK_OUTPUT_PATH=./tree-widget-benchmark.json npm run test:tree-widget",
    "build": "npm run link:deps && tsc",
    "clean": "rimraf lib temp",
    "docs": "betools extract --fileExt=ts --extractFrom=./src --recursive --out=./build/docs/extract",
    "lint": "eslint \"./src/**/*.ts\"",
    "test": "vitest run",
    "test:tree-widget": "vitest run src/tree-widget",
    "test:recreate": "cross-env RECREATE=true npm run test",
    "link:deps": "node ./scripts/linkWorkspaceDeps.cjs"
  },
  "devDependencies": {
    "@bentley/classification-systems-schema": "1.0.4-dev.4",
    "@itwin/build-tools": "^5.7.0",
    "@itwin/core-backend": "^5.7.0",
    "@itwin/core-bentley": "^5.7.0",
    "@itwin/core-common": "^5.7.0",
    "@itwin/core-frontend": "^5.7.0",
    "@itwin/core-geometry": "^5.7.0",
    "@itwin/core-quantity": "^5.7.0",
    "@itwin/core-orbitgt": "^5.7.0",
    "@itwin/ecschema-metadata": "^5.7.0",
    "@itwin/ecschema-rpcinterface-common": "^5.7.0",
    "@itwin/ecschema-rpcinterface-impl": "^5.7.0",
    "@itwin/eslint-plugin": "^6.0.0",
    "@itwin/presentation-backend": "^5.7.0",
    "@itwin/presentation-common": "^5.7.0",
    "@itwin/presentation-frontend": "^5.7.0",
    "@itwin/presentation-core-interop": "2.0.0-alpha.0",
    "@itwin/presentation-hierarchies": "2.0.0-alpha.14",
    "@itwin/presentation-shared": "2.0.0-alpha.9",
    "@itwin/presentation-testing": "^5.4.14",
    "@itwin/tree-widget-react": "workspace:*",
    "@itwin/unified-selection": "^1.6.6",
    "@stratakit/foundations": "^0.4.5",
    "@stratakit/bricks": "^0.5.4",
    "@stratakit/structures": "^0.5.4",
    "@stratakit/icons": "^0.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.8",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "as-table": "^1.0.55",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.3.0",
    "happy-dom": "^20.8.9",
    "vitest": "^4.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.1.2",
    "rxjs": "^7.8.2",
    "sass-embedded": "1.98.0",
    "test-utilities": "workspace:*",
    "typescript": "~5.9.3"
  }
}
