{
  "name": "vcr-performance-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark:tree-widget": "cross-env BENCHMARK_OUTPUT_PATH=./tree-widget-benchmark.json npm run test:tree-widget",
    "build": "npm run link:deps && tsc",
    "clean": "rimraf lib temp",
    "docs": "betools extract --fileExt=ts --extractFrom=./src --recursive --out=./build/docs/extract",
    "lint": "eslint \"./src/**/*.ts\"",
    "test": "vitest run",
    "test:tree-widget": "vitest run src/tree-widget",
    "test:recreate": "cross-env RECREATE=true npm run test",
    "link:deps": "node ./scripts/linkWorkspaceDeps.cjs"
  },
  "devDependencies": {
    "@itwin/appui-abstract": "^5.9.1",
    "@itwin/appui-react": "^5.29.0",
    "@itwin/build-tools": "^5.9.1",
    "@itwin/core-backend": "^5.9.1",
    "@itwin/core-bentley": "^5.9.1",
    "@itwin/core-common": "^5.9.1",
    "@itwin/core-frontend": "^5.9.1",
    "@itwin/core-geometry": "^5.9.1",
    "@itwin/core-orbitgt": "^5.9.1",
    "@itwin/core-quantity": "^5.9.1",
    "@itwin/ecschema-metadata": "^5.9.1",
    "@itwin/ecschema-rpcinterface-common": "^5.9.1",
    "@itwin/ecschema-rpcinterface-impl": "^5.9.1",
    "@itwin/eslint-plugin": "^6.1.0",
    "@itwin/presentation-common": "^5.9.1",
    "@itwin/presentation-core-interop": "^1.3.12",
    "@itwin/presentation-frontend": "^5.9.1",
    "@itwin/presentation-hierarchies": "^1.7.13",
    "@itwin/presentation-shared": "^1.2.12",
    "@itwin/tree-widget-react": "workspace:*",
    "@itwin/unified-selection": "^1.7.2",
    "@types/node": "^22.19.17",
    "as-table": "^1.0.55",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "happy-dom": "^20.9.0",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "sass-embedded": "1.98.0",
    "test-utilities": "workspace:*",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5",
    "vite": "^8.0.10"
  }
}
